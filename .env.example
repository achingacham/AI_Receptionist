GROQ_API_KEY=your_api_key_here
GROQ_MODEL=groq-small
GROQ_API_URL=https://api.groq.com/v1

# Business configuration
BUSINESS_NAME=Your Business Name
BUSINESS_HOURS=Monday-Friday 9am-5pm
BUSINESS_PHONE=+1-555-000-0000
BUSINESS_EMAIL=info@yourbusiness.com
BUSINESS_ADDRESS=123 Main St, City, State 00000

# Receptionist persona
RECEPTIONIST_NAME=Alex
# Cal.com integration
# API key from Cal.com Settings → Developer → API Keys
CALCOM_API_KEY=your_calcom_api_key_here
# Event Type ID — found in the URL when editing an event type on Cal.com (e.g. cal.com/event-types/123 → 123)
CALCOM_EVENT_TYPE_ID=123
# Timezone for interpreting date/time inputs from callers
CALCOM_TIMEZONE=Asia/Kolkata
# Fallback email used when the caller does not provide one
CALCOM_FALLBACK_EMAIL=reception@magnushearing.com
#RECEPTIONIST_TONE=Friendly and professional
#RECEPTIONIST_GREETING=Welcome to Magnus Hearing and Speech Clinic! How can I assist you?