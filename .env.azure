# Azure Deployment Configuration for AI Receptionist
# This file documents the environment variables needed for Azure Container Apps deployment

# Azure Services
KEYVAULT_URI=https://your-kv-name.vault.azure.net/
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=YOUR_KEY_HERE

# Database Connection (for PostgreSQL on Azure)
# Format: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://receptionist_admin:password@your-postgres-server.postgres.database.azure.com:5432/receptionist_db

# Original environment variables (from .env)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1


# Business configuration
BUSINESS_NAME=Your Business Name
BUSINESS_HOURS=Monday-Friday 10am-6:30pm
BUSINESS_PHONE=+1234567890
BUSINESS_EMAIL=info@yourbusiness.com
BUSINESS_ADDRESS=Your Address Here
RECEPTIONIST_NAME=Your Receptionist Name


# Cal.com integration
CALCOM_API_KEY=your_calcom_api_key_here
CALCOM_USERNAME=your_username
CALCOM_EVENT_TYPE_ID=your_event_type_id
CALCOM_TIMEZONE=America/New_York
CALCOM_FALLBACK_EMAIL=fallback@yourbusiness.com

# Voice (Sarvam AI + Twilio/Exotel)
SARVAM_API_KEY=your_sarvam_api_key_here
VOICE_PROVIDER=twilio

# Twilio credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Exotel credentials (alternatively)
EXOTEL_SID=your_exotel_sid
EXOTEL_TOKEN=your_exotel_token
EXOTEL_SUBDOMAIN=your_exotel_subdomain
EXOTEL_PHONE_NUMBER=+91xxxxxxxxxx
